                        <circle cx="50" cy="50" r="12" fill="currentColor"/>
                    </svg>
                    <div class="flex flex-col">
                        <span class="font-serif text-xl font-bold text-white tracking-widest uppercase leading-none">DSD<span class="text-gold font-light">Clinic</span></span>
                        <span class="text-[10px] text-gray-400 tracking-[0.2em] uppercase leading-none mt-1">& Boutique</span>
                    </div>
                </a>

                <nav class="hidden lg:flex space-x-6 text-xs font-semibold text-gray-300 uppercase tracking-widest">
                    <a href="#services" class="hover:text-gold hover:scale-[1.015] transition-all duration-500" data-i18n="nav_services">Services</a>
                    <a href="#heritage" class="hover:text-gold hover:scale-[1.015] transition-all duration-500" data-i18n="nav_heritage">Our Heritage</a>
                    <a href="#boutique" class="hover:text-gold hover:scale-[1.015] transition-all duration-500" data-i18n="nav_boutique">Boutique</a>
                    <a href="#gallery" class="hover:text-gold hover:scale-[1.015] transition-all duration-500" data-i18n="nav_gallery">Gallery</a>
                    <a href="#reviews" class="hover:text-gold hover:scale-[1.015] transition-all duration-500" data-i18n="nav_reviews">Reviews</a>
                    <a href="#contact" class="hover:text-gold hover:scale-[1.015] transition-all duration-500" data-i18n="nav_contact">Contact</a>
