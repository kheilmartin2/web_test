<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DSD Clinic & Boutique | The Pinnacle of Digital Dentistry</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        navy: '#05101e',
                        cream: '#fbfbfa',
                        gold: '#cfa832',
                        'gold-dark': '#96761c'
                    },
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        serif: ['Playfair Display', 'serif'],
                    },
                    animation: {
                        'marquee': 'marquee 45s linear infinite',
                        'pulse-glow': 'pulse-glow 2.5s infinite',
                    },
                    keyframes: {
                        marquee: {
                            '0%': { transform: 'translateX(0%)' },
                            '100%': { transform: 'translateX(-50%)' },
                        },
                        'pulse-glow': {
                            '0%, 100%': { boxShadow: '0 0 15px rgba(207, 168, 50, 0.2)' },
                            '50%': { boxShadow: '0 0 30px rgba(207, 168, 50, 0.6)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #fbfbfa; overflow-x: hidden; }
        h1, h2, h3, h4, .font-serif { font-family: 'Playfair Display', serif; }
        
        .lang-btn.active { color: #cfa832; border-bottom: 2px solid #cfa832; text-shadow: 0 0 10px rgba(207,168,50,0.3); }

        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: #05101e; }
        ::-webkit-scrollbar-thumb { background: #cfa832; border-radius: 3px; }

        .slider-container { --pos: 50%; position: relative; width: 100%; height: 100%; cursor: ew-resize; }
        .image-before { clip-path: polygon(0 0, var(--pos) 0, var(--pos) 100%, 0 100%); }
        .slider-line { left: var(--pos); transform: translateX(-50%); }
        input[type=range]::-webkit-slider-thumb { appearance: none; width: 40px; height: 40px; background: transparent; cursor: ew-resize; }

        .fade-transition { transition: opacity 0.4s ease-in-out; }
    </style>
</head>
<body class="text-gray-800 antialiased selection:bg-gold selection:text-navy">

