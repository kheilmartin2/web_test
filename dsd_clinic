                    <div class="absolute inset-0 bg-navy/10 group-hover:bg-transparent transition-colors duration-1000"></div>
                </div>
            </div>
        </div>
    </section>

    <div id="heritage-modal" class="fixed inset-0 z-[60] bg-navy/95 backdrop-blur-md hidden items-center justify-center p-4 opacity-0 transition-opacity duration-500">
        <div class="bg-cream max-w-3xl w-full max-h-[90vh] overflow-y-auto relative transform scale-95 transition-transform duration-500 shadow-2xl rounded-2xl">
