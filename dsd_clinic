            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-serif text-navy mb-4" data-i18n="shop_title">DSD Boutique</h2>
                <div class="w-16 h-1 bg-gold mx-auto mb-6"></div>
                <p class="text-gray-500 uppercase tracking-widest text-xs font-bold" data-i18n="shop_sub">Premium Oral Curations</p>
            </div>
            
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8" id="shop-grid">
                </div>
        </div>
