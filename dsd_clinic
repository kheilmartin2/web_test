                        <span class="block text-gold text-[10px] uppercase tracking-widest mb-2" data-i18n="mod_time_lbl">Time Required</span>
                        <span class="font-bold text-sm md:text-base" id="mod-time">Time</span>
                    </div>
                    <div class="p-5 bg-navy text-white text-center border-l border-white/10 rounded-xl">
                        <span class="block text-gold text-[10px] uppercase tracking-widest mb-2" data-i18n="mod_price_lbl">Est. Investment</span>
                        <span class="font-bold text-sm md:text-base" id="mod-price">Price</span>
                    </div>
                </div>
                <button id="book-procedure-btn" class="block w-full text-center bg-gold text-navy font-bold uppercase tracking-widest py-5 rounded-xl hover:bg-navy hover:text-white hover:scale-[1.015] transition-all duration-500 shadow-lg" data-i18n="mod_book">Book This Procedure</button>
            </div>
        </div>
    </div>

    <section id="heritage" class="py-24 bg-white border-t border-gray-100">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                <div>
                    <span class="text-gold text-xs font-bold uppercase tracking-widest mb-4 block" data-i18n="her_badge">Our Heritage</span>
                    <h2 class="text-4xl md:text-5xl font-serif text-navy mb-6 leading-tight" data-i18n="her_title">A Legacy of Precision & Artistry.</h2>
                    <p class="text-gray-600 text-lg mb-6 leading-relaxed font-light" data-i18n="her_p1">Founded by visionary specialists in Oaxaca, our clinic has evolved into a global center for digital dentistry, strictly dedicated to high-end, painless procedures for the North American elite.</p>
                    <p class="text-gray-600 text-lg mb-10 leading-relaxed font-light" data-i18n="her_p2">Combining 3D CAD/CAM technology with Swiss engineering and a Ritz-Carlton approach to patient comfort.</p>
                    <button onclick="openModal('heritage-modal')" class="inline-flex items-center gap-2 text-navy hover:text-gold font-bold uppercase tracking-widest text-xs transition-colors duration-300 group">
                        <span data-i18n="her_btn">Read Full History</span>
                        <span class="group-hover:translate-x-1 transition-transform">→</span>
                    </button>
                </div>
                <div class="relative h-[500px] rounded-2xl overflow-hidden shadow-[0_20px_40px_rgba(5,16,30,0.1)] group cursor-pointer hover:scale-[1.015] transition-all duration-500" onclick="openModal('heritage-modal')">
