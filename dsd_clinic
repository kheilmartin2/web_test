            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="services-grid">
                </div>
        </div>
    </section>

    <div id="service-modal" class="fixed inset-0 z-[60] bg-navy/95 backdrop-blur-md hidden items-center justify-center p-4 opacity-0 transition-opacity duration-500">
        <div class="bg-white max-w-3xl w-full max-h-[90vh] overflow-y-auto relative transform scale-95 transition-transform duration-500 shadow-2xl rounded-2xl">
