                <span id="cart-total">$0</span>
            </div>
            <button onclick="checkout()" class="w-full bg-gold text-navy font-bold uppercase tracking-widest py-4 rounded-xl hover:bg-navy hover:text-white hover:scale-[1.015] transition-all duration-500 shadow-md" data-i18n="cart_checkout">Proceed to Checkout</button>
        </div>
    </div>
    <div id="cart-overlay" onclick="toggleCart()" class="fixed inset-0 bg-navy/60 backdrop-blur-sm z-40 hidden opacity-0 transition-opacity duration-500"></div>

    <section class="relative h-screen flex items-center justify-center bg-navy overflow-hidden">
        <div class="absolute inset-0 z-0">
            <img src="https://images.unsplash.com/photo-1600170311833-c2cf5280ce49?ixlib=rb-4.0.3&auto=format&fit=crop&w=2000&q=80" alt="Clinic Ambience" class="w-full h-full object-cover opacity-20 mix-blend-luminosity">
            <div class="absolute inset-0 bg-gradient-to-b from-navy/90 via-navy/50 to-navy"></div>
        </div>
        <div class="relative z-10 text-center max-w-4xl mx-auto px-4 mt-20">
            <h1 class="text-5xl md:text-7xl font-serif text-white mb-6 leading-tight drop-shadow-2xl" data-i18n="hero_title">The Future of Your Smile, <br><span class="text-gold italic">Engineered in Digital 3D.</span></h1>
            <p class="text-lg text-gray-300 mb-10 font-light max-w-2xl mx-auto leading-relaxed" data-i18n="hero_subtitle">The Ritz-Carlton of dentistry. Uncompromising aesthetics and pain-free precision for North America's most demanding clientele.</p>
        </div>
        <div class="absolute bottom-0 w-full bg-white/5 backdrop-blur-md border-t border-white/10 py-8 z-20">
            <div class="max-w-7xl mx-auto px-4 grid grid-cols-3 gap-4 text-center divide-x divide-white/10">
                <div>
