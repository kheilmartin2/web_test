                        <div class="mt-auto pt-4 flex flex-col">
                            <span class="font-bold text-navy text-2xl mb-4">$${item.price}</span>
                            <button onclick="addToCart(${item.id})" class="w-full bg-navy text-white text-xs uppercase tracking-widest py-3.5 rounded-xl hover:bg-gold hover:text-navy hover:scale-[1.02] transition-all duration-300 font-bold shadow-md">${i18n[currentLang].shop_add}</button>
                        </div>
                    </div>`;
            });
        }

        function renderMarquee() {
            const brands = [
                { name: "Straumann", flag: flags.ch, url: "https://www.straumann.com" },
                { name: "Invisalign", flag: flags.us, url: "https://www.invisalign.com" },
                { name: "Dentsply Sirona", flag: flags.us, url: "https://www.dentsplysirona.com" },
                { name: "Ivoclar", flag: flags.li, url: "https://www.ivoclar.com" },
                { name: "Nobel Biocare", flag: flags.se, url: "https://www.nobelbiocare.com" },
                { name: "Lasak", flag: flags.cz, url: "https://www.lasak.com" },
                { name: "Kavo", flag: flags.de, url: "https://www.kavo.com" },
                { name: "GC Dental", flag: flags.jp, url: "https://www.gcdental.com" },
                { name: "3M ESPE", flag: flags.us, url: "https://www.3m.com" },
                { name: "MIS", flag: flags.il, url: "https://www.mis-implants.com" }
            ];
            const track = document.getElementById('marquee-track');
            const items = brands.map(b => `
                <a href="${b.url}" target="_blank" class="inline-flex items-center gap-4 bg-white/5 border border-white/10 px-8 py-4 rounded-full mx-4 hover:border-gold hover:bg-white/10 transition-all duration-300 group">
                    ${b.flag}
                    <span class="font-bold text-white text-xs uppercase tracking-widest group-hover:text-gold transition-colors">${b.name}</span>
                </a>
            `).join('');
            track.innerHTML = items + items + items;
        }

        function renderHeritageTimeline() {
            const container = document.getElementById('timeline-container');
            container.innerHTML = '';
            heritageData.forEach((item, index) => {
                const align = index % 2 === 0 ? 'md:flex-row-reverse' : 'md:flex-row';
                const textDir = index % 2 === 0 ? 'md:text-left' : 'md:text-right';
                container.innerHTML += `
                    <div class="relative flex flex-col md:flex-row items-center justify-between w-full">
                        <div class="absolute left-5 md:left-1/2 w-4 h-4 rounded-full bg-gold shadow-[0_0_10px_rgba(207,168,50,0.8)] -translate-x-1.5 md:-translate-x-1/2 z-10 border-4 border-cream"></div>
                        <div class="w-full md:w-5/12 pl-12 md:pl-0 ${textDir}">
                            <span class="block text-2xl font-serif text-gold mb-2">${item.year}</span>
                            <p class="text-gray-600 text-sm leading-relaxed">${item[currentLang]}</p>
                        </div>
                        <div class="hidden md:block w-5/12"></div>
                    </div>`;
            });
        }

        function renderReview() {
            const elTxt = document.getElementById('review-text');
            const meta = document.getElementById('review-meta');
            elTxt.style.opacity = 0;
            meta.style.opacity = 0;
            
            setTimeout(() => {
                elTxt.innerText = reviewData[rIdx][currentLang];
                document.getElementById('review-author').innerText = reviewData[rIdx].author;
                document.getElementById('review-loc').innerHTML = `<span class="text-green-500 mr-1">✓</span> Verified Patient - ${reviewData[rIdx].loc}`;
                elTxt.style.opacity = 1;
                meta.style.opacity = 1;
            }, 400);
        }

        function changeReview(dir) {
            rIdx = (rIdx + dir + reviewData.length) % reviewData.length;
            renderReview();
        }

        function changeLang(lang) {
            currentLang = lang;
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            document.querySelectorAll('[data-i18n]').forEach(el => { const key = el.getAttribute('data-i18n'); if (i18n[lang][key]) el.innerHTML = i18n[lang][key]; });
            document.querySelectorAll('[data-i18n-ph]').forEach(el => { const key = el.getAttribute('data-i18n-ph'); if (i18n[lang][key]) el.placeholder = i18n[lang][key]; });
            
            renderServices(); renderBoutique(); updateCartUI(); renderReview(); renderHeritageTimeline();
        }

        function openServiceModal(id) {
            const srv = servicesData.find(s => s.id === id);
            const langData = srv[currentLang];
            document.getElementById('mod-title').innerText = langData.title;
            document.getElementById('mod-desc').innerText = langData.desc;
            document.getElementById('mod-journey').innerHTML = langData.journey;
            document.getElementById('mod-time').innerText = langData.time;
            document.getElementById('mod-price').innerText = langData.price;
            
            const btn = document.getElementById('book-procedure-btn');
            btn.onclick = () => { 
                closeModal('service-modal'); 
                document.getElementById('form-service-select').value = id;
                setTimeout(() => window.location.href = '#contact', 400);
            };
            const modal = document.getElementById('service-modal');
            modal.classList.remove('hidden'); modal.classList.add('flex');
            setTimeout(() => { modal.classList.remove('opacity-0'); modal.children[0].classList.remove('scale-95'); }, 10);
        }

        function openModal(modalId) {
            const modal = document.getElementById(modalId);
            modal.classList.remove('hidden'); modal.classList.add('flex');
            setTimeout(() => { modal.classList.remove('opacity-0'); modal.children[0].classList.remove('scale-95'); }, 10);
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);
            modal.classList.add('opacity-0'); modal.children[0].classList.add('scale-95');
            setTimeout(() => { modal.classList.add('hidden'); modal.classList.remove('flex'); }, 500);
        }

        function toggleCart() {
            const drawer = document.getElementById('cart-drawer');
            const overlay = document.getElementById('cart-overlay');
            if(drawer.classList.contains('translate-x-full')) {
                overlay.classList.remove('hidden'); setTimeout(() => { overlay.classList.remove('opacity-0'); drawer.classList.remove('translate-x-full'); }, 10);
            } else {
                drawer.classList.add('translate-x-full'); overlay.classList.add('opacity-0'); setTimeout(() => { overlay.classList.add('hidden'); }, 500);
            }
        }

        function addToCart(id) {
            const item = boutiqueData.find(i => i.id === id);
            const existing = cart.find(i => i.id === id);
            if(existing) existing.qty++; else cart.push({...item, qty: 1});
            updateCartUI();
            const badge = document.getElementById('cart-badge');
            badge.classList.add('scale-150'); setTimeout(() => badge.classList.remove('scale-150'), 200);
        }

        function remFromCart(id) { cart = cart.filter(i => i.id !== id); updateCartUI(); }

        function updateCartUI() {
            const itemsContainer = document.getElementById('cart-items');
            const totalContainer = document.getElementById('cart-total');
            const badge = document.getElementById('cart-badge');
            badge.innerText = cart.reduce((sum, i) => sum + i.qty, 0);
            if(cart.length === 0) {
                itemsContainer.innerHTML = `<p class="text-gray-500 text-center mt-10 text-sm font-medium">${i18n[currentLang].cart_empty}</p>`;
                totalContainer.innerText = "$0"; return;
            }
            let total = 0; itemsContainer.innerHTML = '';
            cart.forEach(item => {
                total += item.price * item.qty;
                itemsContainer.innerHTML += `
                    <div class="flex items-center gap-4 bg-white p-4 border border-gray-100 rounded-2xl shadow-sm">
                        <img src="${item.img}" class="w-14 h-14 object-cover rounded-xl border border-gray-50 mix-blend-multiply">
                        <div class="flex-1">
                            <h4 class="text-xs font-bold text-navy line-clamp-1 mb-1">${item.name}</h4>
                            <p class="text-gold text-sm font-bold">$${item.price} <span class="text-gray-400 text-[10px]">x${item.qty}</span></p>
                        </div>
                        <button onclick="remFromCart(${item.id})" class="w-8 h-8 flex items-center justify-center rounded-full bg-gray-50 text-gray-400 hover:text-red-500 hover:bg-red-50 transition-colors font-bold">×</button>
                    </div>`;
            });
            totalContainer.innerText = `$${total}`;
        }

        function checkout() {
            if(cart.length === 0) return;
            alert(currentLang === 'en' ? "Simulating Secure Apple Pay / Stripe Checkout..." : (currentLang === 'es' ? "Simulando pago seguro..." : "Simulation de paiement sécurisé..."));
            cart = []; updateCartUI(); toggleCart();
        }

        function handleForm(e) {
            e.preventDefault();
            const email = document.getElementById('form-email');
            if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.value)) {
                email.classList.add('border-red-500', 'ring-red-500/50'); document.getElementById('email-err').classList.remove('hidden'); return;
            }
            email.classList.remove('border-red-500', 'ring-red-500/50'); document.getElementById('email-err').classList.add('hidden');
            
            document.getElementById('contact-form').style.display = 'none';
            const succ = document.getElementById('form-success');
            succ.classList.remove('hidden'); succ.classList.add('flex'); setTimeout(() => succ.classList.remove('opacity-0'), 50);
        }

        document.addEventListener("DOMContentLoaded", () => {
            renderServices(); renderBoutique(); renderMarquee(); renderReview(); renderHeritageTimeline();
            const observer = new IntersectionObserver(entries => {
                entries.forEach(entry => {
                    if(entry.isIntersecting) {
                        const target = +entry.target.getAttribute('data-target');
                        let count = 0, inc = target / 50;
                        const update = () => {
                            if(count < target) { count += inc; entry.target.innerText = Math.ceil(count); setTimeout(update, 30); }
                            else { entry.target.innerText = target; }
                        };
                        update(); observer.unobserve(entry.target);
                    }
                });
            });
            document.querySelectorAll('.counter').forEach(c => observer.observe(c));
        });
    </script>
</body>
</html>
