                    <div class="text-[10px] md:text-xs text-gray-400 uppercase tracking-widest font-semibold" data-i18n="stat_1">Perfect Smiles</div>
                </div>
                <div>
                    <div class="text-2xl md:text-4xl font-serif text-gold mb-1"><span class="counter" data-target="25">0</span>+</div>
                    <div class="text-[10px] md:text-xs text-gray-400 uppercase tracking-widest font-semibold" data-i18n="stat_2">Years Mastery</div>
                </div>
                <div>
                    <div class="text-2xl md:text-4xl font-serif text-gold mb-1">0%</div>
                    <div class="text-[10px] md:text-xs text-gray-400 uppercase tracking-widest font-semibold" data-i18n="stat_3">Pain Guarantee</div>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="py-24 bg-cream relative">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-4xl md:text-5xl font-serif text-navy mb-4" data-i18n="srv_title">Executive Dental Architecture</h2>
