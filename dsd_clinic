    <section class="py-12 bg-navy overflow-hidden">
        <div class="relative w-full flex">
            <div id="marquee-track" class="flex whitespace-nowrap animate-marquee w-[200%] items-center">
                </div>
        </div>
    </section>

    <section id="gallery" class="py-24 bg-white">
        <div class="max-w-6xl mx-auto px-4">
            <div class="text-center mb-12">
                <h2 class="text-4xl md:text-5xl font-serif text-navy mb-4" data-i18n="gal_title">The Art of Transformation</h2>
